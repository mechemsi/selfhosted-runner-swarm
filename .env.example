# Primary GitHub PAT (used as default across pools unless overridden in config.yml)
# Permissions: Actions (read/write), Administration (read/write)
GITHUB_PAT=github_pat_

# Second account PAT (optional — only needed if you have pools for other orgs/accounts)
# CLIENT_GITHUB_PAT=ghp_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Global poll interval in seconds — applies to all pools
POLL_INTERVAL=15

