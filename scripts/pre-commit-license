#!/usr/bin/env bash
set -euo pipefail

# Copyright (c) 2026 Mechemsi. All rights reserved.
# Licensed under the MIT License. See LICENSE file in the project root.

# Git pre-commit hook: check that staged .py/.sh files have the license header.

REPO_ROOT="$(git rev-parse --show-toplevel)"
MARKER="Copyright (c) 2026 Mechemsi"

staged_files="$(git diff --cached --name-only --diff-filter=ACM -- '*.py' '*.sh')"

if [[ -z "$staged_files" ]]; then
    exit 0
fi

missing=0
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    filepath="$REPO_ROOT/$file"
    if [[ -f "$filepath" ]] && ! grep -qF "$MARKER" "$filepath"; then
        echo "LICENSE HEADER MISSING: $file"
        missing=$((missing + 1))
    fi
done <<< "$staged_files"

if [[ $missing -gt 0 ]]; then
    echo ""
    echo "$missing staged file(s) missing license header."
    echo "Run: ./scripts/license-header.sh fix"
    echo "Then re-stage the fixed files."
    exit 1
fi
